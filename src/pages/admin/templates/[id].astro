---
/**
 * Edit template page.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const id = Astro.params.id;
const returnPage = Astro.url.searchParams.get('page') || '1';
---

<AdminLayout
  title="Edit Template"
  currentPath={`/admin/plugins/notifications/templates/${id}`}
  user={user}
>
  <div class="col-span-12 max-w-3xl">
    <h1 class="text-2xl font-bold mb-6">Edit Template</h1>

    {/* Form */}
    <form id="template-form">
      {/* Name */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Template Name</span>
        </label>
        <input type="text" name="name" class="input input-bordered w-full" required />
      </div>

      {/* Subject */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Subject</span>
        </label>
        <input type="text" name="subject" class="input input-bordered w-full" required />
      </div>

      {/* Body HTML */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Body (HTML)</span>
        </label>
        <textarea name="body_html" class="textarea textarea-bordered w-full h-48 font-mono text-sm"
        ></textarea>
      </div>

      {/* Body Text */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Body (Plain Text)</span>
        </label>
        <textarea name="body_text" class="textarea textarea-bordered w-full h-32 font-mono text-sm"
        ></textarea>
      </div>

      {/* Actions */}
      <div class="flex gap-2">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href={`/admin/plugins/notifications/templates?page=${returnPage}`} class="btn btn-ghost"
          >Cancel</a
        >
        <button type="button" class="btn btn-error btn-sm ml-auto" id="delete-btn">Delete</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  document.getElementById('template-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const body = Object.fromEntries(formData.entries());

    const res = await fetch(
      `/api/plugins/notifications/templates/${window.location.pathname.split('/').pop()}`,
      {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }
    );

    if (res.ok) {
      window.location.href = `/admin/plugins/notifications/templates?page=${new URLSearchParams(window.location.search).get('page') || '1'}`;
    } else {
      const err = await res.json();
      alert(err.error || 'Failed to save template');
    }
  });

  document.getElementById('delete-btn').addEventListener('click', async () => {
    if (
      !confirm(
        'Are you sure you want to delete this template? It cannot be deleted if rules reference it.'
      )
    )
      return;
    const id = window.location.pathname.split('/').pop();
    const res = await fetch(`/api/plugins/notifications/templates/${id}`, { method: 'DELETE' });
    if (res.status === 409) {
      const err = await res.json();
      alert(err.error);
      return;
    }
    window.location.href = '/admin/plugins/notifications/templates';
  });
</script>
