---
/**
 * Templates list page — paginated list of notification templates.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { db } from 'astro:db';
import { listTemplates } from '../../../lib/data/templates.ts';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const url = new URL(Astro.url);
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));
const limit = 20;
const search = url.searchParams.get('search') || '';

// Read templates directly via the accessor (server-side fetch of our own
// admin-gated API would 401 — the session cookie isn't forwarded).
let templates = [];
let pagination = { page: 1, limit: 20, total: 0, totalPages: 1 };
try {
  const result = await listTemplates(db, { page, limit, search: search || undefined });
  templates = result.data;
  pagination = {
    page,
    limit,
    total: result.total,
    totalPages: Math.max(1, Math.ceil(result.total / limit)),
  };
} catch {
  // Silently fail
}
---

<AdminLayout title="Templates" currentPath="/admin/plugins/notifications/templates" user={user}>
  <div class="col-span-12">
    {/* Header */}
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold">Notification Templates</h1>
      <a href="/admin/plugins/notifications/templates/new" class="btn btn-primary">New Template</a>
    </div>

    {/* Search */}
    <div class="flex gap-4 mb-4">
      <input
        type="search"
        placeholder="Search templates..."
        class="input input-bordered flex-1 max-w-xs"
        value={search}
        id="search-input"
      />
    </div>

    {/* Templates Table */}
    {templates.length === 0 ? (
      <p class="text-base-content/60">No templates found.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Name</th>
              <th>Subject</th>
              <th>Has HTML</th>
              <th>Has Text</th>
              <th>Created</th>
              <th />
            </tr>
          </thead>
          <tbody>
            {templates.map((t) => (
              <tr>
                <td class="font-medium">{t.name}</td>
                <td class="max-w-xs truncate" title={t.subject}>{t.subject}</td>
                <td>
                  <span class={`badge badge-sm ${t.body_html ? 'badge-success' : 'badge-ghost'}`}>
                    {t.body_html ? 'Yes' : 'No'}
                  </span>
                </td>
                <td>
                  <span class={`badge badge-sm ${t.body_text ? 'badge-success' : 'badge-ghost'}`}>
                    {t.body_text ? 'Yes' : 'No'}
                  </span>
                </td>
                <td>{new Date(t.created_at).toLocaleDateString()}</td>
                <td>
                  <a href={`/admin/plugins/notifications/templates/${t.id}`} class="btn btn-ghost btn-xs">Edit</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {/* Pagination */}
    {pagination.totalPages > 1 && (
      <div class="flex justify-center mt-6 gap-2">
        {pagination.page > 1 && (
          <a href={`?page=${pagination.page - 1}${search ? `&search=${search}` : ''}`} class="btn btn-sm">← Prev</a>
        )}
        <span class="btn btn-sm btn-disabled">Page {pagination.page} of {pagination.totalPages}</span>
        {pagination.page < pagination.totalPages && (
          <a href={`?page=${pagination.page + 1}${search ? `&search=${search}` : ''}`} class="btn btn-sm">Next →</a>
        )}
      </div>
    )}
  </div>
</AdminLayout>

<script>
  document.getElementById('search-input').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      const q = e.target.value;
      window.location.href = '/admin/plugins/notifications/templates' + (q ? `?search=${q}` : '');
    }
  });
</script>
