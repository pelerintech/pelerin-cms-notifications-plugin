---
/**
 * Create new template page.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
---

<AdminLayout title="New Template" currentPath="/admin/plugins/notifications/templates/new" user={user}>
  <div class="col-span-12 max-w-3xl">
    <h1 class="text-2xl font-bold mb-6">Create New Template</h1>

    {/* Form */}
    <form id="template-form" method="POST" action="/api/plugins/notifications/templates">
      {/* Name */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Template Name</span>
        </label>
        <input
          type="text"
          name="name"
          placeholder="Order Confirmation"
          class="input input-bordered w-full"
          required
        />
      </div>

      {/* Subject */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Subject</span>
          <span class="label-text-alt text-base-content/50">Use &#123;&#123; field &#125;&#125; for dynamic values</span>
        </label>
        <input
          type="text"
          name="subject"
          placeholder="Your order &#123;&#123; order.number &#125;&#125; has been confirmed"
          class="input input-bordered w-full"
          required
        />
      </div>

      {/* Body HTML */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Body (HTML)</span>
        </label>
        <textarea
          name="body_html"
          placeholder="<h1>Thank you for your order!</h1><p>Order: &#123;&#123; order.number &#125;&#125;</p>"
          class="textarea textarea-bordered w-full h-48 font-mono text-sm"
        ></textarea>
      </div>

      {/* Body Text */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Body (Plain Text)</span>
          <span class="label-text-alt text-base-content/50">Fallback for email clients that don't support HTML</span>
        </label>
        <textarea
          name="body_text"
          placeholder="Thank you for your order! Order: &#123;&#123; order.number &#125;&#125;"
          class="textarea textarea-bordered w-full h-32 font-mono text-sm"
        ></textarea>
      </div>

      {/* Actions */}
      <div class="flex gap-2">
        <button type="submit" class="btn btn-primary">Create Template</button>
        <a href="/admin/plugins/notifications/templates" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>
