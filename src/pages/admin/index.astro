---
/**
 * Notifications admin dashboard — grid of navigation cards.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const navCards = [
  {
    title: 'Rules',
    description: 'Manage event-to-notification routing rules',
    icon: '📋',
    href: '/admin/plugins/notifications/rules',
    color: 'primary',
  },
  {
    title: 'Templates',
    description: 'Create and edit email templates with {{ }} variables',
    icon: '📝',
    href: '/admin/plugins/notifications/templates',
    color: 'secondary',
  },
  {
    title: 'Providers',
    description: 'Configure email providers (SendGrid, Mailgun, SES, SMTP)',
    icon: '📤',
    href: '/admin/plugins/notifications/providers',
    color: 'accent',
  },
  {
    title: 'Logs',
    description: 'View dispatch logs and audit trail',
    icon: '📊',
    href: '/admin/plugins/notifications/logs',
    color: 'neutral',
  },
];
---

<AdminLayout title="Notifications" currentPath="/admin/plugins/notifications" user={user}>
  <div class="col-span-12">
    {/* Navigation Cards Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-4xl">
      {
        navCards.map((card) => (
          <a
            href={card.href}
            class={`card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow border-t-4 border-${card.color}`}
          >
            <div class="card-body">
              <div class="text-4xl mb-2">{card.icon}</div>
              <h2 class="card-title text-lg">{card.title}</h2>
              <p class="text-sm text-base-content/60">{card.description}</p>
              <div class="card-actions justify-end mt-4">
                <span class="btn btn-sm btn-{card.color}">Manage →</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</AdminLayout>
