---
/**
 * Create new rule page.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { listTemplates } from '../../../lib/data/templates.ts';
import { listAvailableProvidersHandler } from '../../../api/notifications/rules/providers.ts';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

// Read templates directly via the accessor (server-side fetch of our own
// admin-gated API would 401 — the session cookie isn't forwarded). Matches the
// ecomm_plugin page pattern and AGENTS.md §5 (pages obtain db from sdk.db).
let templates = [];
try {
  const result = await listTemplates(sdk.db, { page: 1, limit: 1000 });
  templates = result.data;
} catch {
  // Silently fail
}

// Available providers (registry-derived, channel+configured-filtered,
// local-excluded, mode-aware) via the handler directly. Replaces the former
// hardcoded `availableProviders` array that drifted out of sync with the registry.
let availableProviders = [];
try {
  const result = await listAvailableProvidersHandler(sdk.db, 'email');
  availableProviders = result.body.data;
} catch {
  // Silently fail — empty dropdown shown
}

// UI-side label/icon map for provider display names. A provider missing from
// this map renders as its raw `name` (visible degradation, not a silent
// disappearance from the dropdown) so drift becomes observable.
const providerLabels = {
  sendgrid: 'SendGrid',
  mailgun: 'Mailgun',
  ses: 'AWS SES',
  smtp: 'SMTP',
  brevo: 'Brevo',
};
function providerLabel(name) {
  return providerLabels[name] || name;
}
---

<AdminLayout title="New Rule" currentPath="/admin/plugins/notifications/rules/new" user={user}>
  <div class="col-span-12 max-w-2xl">
    <h1 class="text-2xl font-bold mb-6">Create New Rule</h1>

    {/* Form */}
    <form id="rule-form" method="POST" action="/api/plugins/notifications/rules">
      {/* Event Pattern */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Event Pattern</span>
          <span class="label-text-alt text-base-content/50"
            >e.g., shop.order.created, shop.*, *</span
          >
        </label>
        <input
          type="text"
          name="event_pattern"
          placeholder="shop.order.created"
          class="input input-bordered w-full"
          required
        />
      </div>

      {/* Template */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Template</span>
        </label>
        <select name="template_id" class="select select-bordered w-full" required>
          <option disabled selected>Select a template</option>
          {templates.map((t) => <option value={t.id}>{t.name}</option>)}
        </select>
      </div>

      {/* Channel */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Channel</span>
          <span class="label-text-alt text-base-content/50">Email today (SMS/push coming)</span>
        </label>
        <select name="channel" class="select select-bordered w-full" required>
          <option value="email" selected>Email</option>
        </select>
      </div>

      {/* Provider */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Provider</span>
        </label>
        <select name="provider_name" class="select select-bordered w-full" required>
          <option disabled selected>Select a provider</option>
          {availableProviders.map((p) => <option value={p.name}>{providerLabel(p.name)}</option>)}
        </select>
      </div>

      {/* Recipients */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">To</span>
          <span class="label-text-alt text-base-content/50"
            >Email or &#123;&#123; field &#125;&#125;</span
          >
        </label>
        <input
          type="text"
          name="to"
          placeholder="customer@example.com or {{ customer_email }}"
          class="input input-bordered w-full"
          required
        />
      </div>

      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">CC (optional)</span>
        </label>
        <input
          type="text"
          name="cc"
          placeholder="admin@example.com"
          class="input input-bordered w-full"
        />
      </div>

      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">BCC (optional)</span>
        </label>
        <input
          type="text"
          name="bcc"
          placeholder="archive@example.com"
          class="input input-bordered w-full"
        />
      </div>

      {/* Active toggle */}
      <div class="form-control mb-6">
        <label class="label cursor-pointer">
          <span class="label-text font-medium">Active</span>
          <input type="checkbox" name="active" class="toggle toggle-success" checked />
        </label>
      </div>

      {/* Actions */}
      <div class="flex gap-2">
        <button type="submit" class="btn btn-primary">Create Rule</button>
        <a href="/admin/plugins/notifications/rules" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>
