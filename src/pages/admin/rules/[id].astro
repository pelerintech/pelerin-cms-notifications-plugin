---
/**
 * Edit rule page.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { listTemplates } from '../../../lib/data/templates.ts';
import { getRule } from '../../../lib/data/rules.ts';
import { listAvailableProvidersForChannel } from '../../../lib/data/providers.ts';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const id = Astro.params.id;
const returnPage = Astro.url.searchParams.get('page') || '1';

// Load the rule being edited directly via accessors (server-side fetch of our
// own admin-gated API would 401 — the session cookie isn't forwarded).
let rule = null;
let templates = [];

try {
  rule = await getRule(sdk.db, id);
} catch {
  // Silently fail
}

try {
  const result = await listTemplates(sdk.db, { page: 1, limit: 1000 });
  templates = result.data;
} catch {
  // Silently fail
}

// Available providers (registry-derived, channel+configured-filtered,
// local-excluded, mode-aware) via the shared accessor. Replaces the former
// hardcoded `availableProviders` array and the broken endpoint import.
const isDev = process.env.NOTIFICATIONS_DEV_MODE === 'true';
let availableProviders = [];
try {
  const channel = rule?.channel || 'email';
  availableProviders = await listAvailableProvidersForChannel(sdk.db, channel, isDev);
} catch {
  // Silently fail — empty dropdown shown
}

// UI-side label map for provider display names. A provider missing from this
// map renders as its raw `name` (visible degradation, not a silent disappearance).
const providerLabels = {
  sendgrid: 'SendGrid',
  mailgun: 'Mailgun',
  ses: 'AWS SES',
  smtp: 'SMTP',
  brevo: 'Brevo',
};
function providerLabel(name) {
  return providerLabels[name] || name;
}
---

<AdminLayout title="Edit Rule" currentPath={`/admin/plugins/notifications/rules/${id}`} user={user}>
  <div class="col-span-12 max-w-2xl">
    <h1 class="text-2xl font-bold mb-6">Edit Rule</h1>

    {/* Form */}
    <form id="rule-form" method="POST">
      <input type="hidden" name="_method" value="PUT" />

      {/* Event Pattern */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Event Pattern</span>
        </label>
        <input
          type="text"
          name="event_pattern"
          class="input input-bordered w-full"
          value={rule?.event_pattern || ''}
          required
        />
      </div>

      {/* Template */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Template</span>
        </label>
        <select name="template_id" class="select select-bordered w-full" required>
          <option disabled selected={!rule?.template_id}>Select a template</option>
          {
            templates.map((t) => (
              <option value={t.id} selected={rule?.template_id === t.id}>
                {t.name}
              </option>
            ))
          }
        </select>
      </div>

      {/* Channel */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Channel</span>
        </label>
        <select name="channel" class="select select-bordered w-full" required>
          <option value="email" selected={rule?.channel === 'email' || !rule}>Email</option>
        </select>
      </div>

      {/* Provider */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">Provider</span>
        </label>
        <select name="provider_name" class="select select-bordered w-full" required>
          <option disabled selected={!rule?.provider_name}>Select a provider</option>
          {
            availableProviders.map((p) => (
              <option value={p.name} selected={rule?.provider_name === p.name}>
                {providerLabel(p.name)}
              </option>
            ))
          }
        </select>
      </div>

      {/* Recipients */}
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">To</span>
        </label>
        <input
          type="text"
          name="to"
          class="input input-bordered w-full"
          value={rule?.to || ''}
          required
        />
      </div>

      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">CC (optional)</span>
        </label>
        <input type="text" name="cc" class="input input-bordered w-full" value={rule?.cc || ''} />
      </div>

      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text font-medium">BCC (optional)</span>
        </label>
        <input type="text" name="bcc" class="input input-bordered w-full" value={rule?.bcc || ''} />
      </div>

      {/* Active toggle */}
      <div class="form-control mb-6">
        <label class="label cursor-pointer">
          <span class="label-text font-medium">Active</span>
          <input
            type="checkbox"
            name="active"
            class="toggle toggle-success"
            checked={rule?.active ?? false}
          />
        </label>
      </div>

      {/* Actions */}
      <div class="flex gap-2">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href={`/admin/plugins/notifications/rules?page=${returnPage}`} class="btn btn-ghost"
          >Cancel</a
        >
        <button type="button" class="btn btn-error btn-sm ml-auto" id="delete-btn">Delete</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  document.getElementById('rule-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const body = Object.fromEntries(formData.entries());
    body.active = body.active === 'on';
    delete body._method;

    const res = await fetch(
      `/api/plugins/notifications/rules/${window.location.pathname.split('/').pop()}`,
      {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }
    );

    if (res.ok) {
      window.location.href = `/admin/plugins/notifications/rules?page=${new URLSearchParams(window.location.search).get('page') || '1'}`;
    } else {
      const err = await res.json();
      alert(err.error || 'Failed to save rule');
    }
  });

  document.getElementById('delete-btn').addEventListener('click', async () => {
    if (!confirm('Are you sure you want to delete this rule?')) return;
    const id = window.location.pathname.split('/').pop();
    await fetch(`/api/plugins/notifications/rules/${id}`, { method: 'DELETE' });
    window.location.href = '/admin/plugins/notifications/rules';
  });
</script>
