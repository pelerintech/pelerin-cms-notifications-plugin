---
/**
 * Rules list page — paginated list of notification rules.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { listRules } from '../../../lib/data/rules.ts';
import { listAvailableProvidersHandler } from '../../../api/notifications/rules/providers.ts';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const url = new URL(Astro.url);
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));
const limit = 20;
const search = url.searchParams.get('search') || '';
const activeFilter = url.searchParams.get('active');

// Read rules directly via the accessor (server-side fetch of our own admin-gated
// API would 401 — the session cookie isn't forwarded). Matches ecomm + AGENTS.md §5.
let rules = [];
let pagination = { page: 1, limit: 20, total: 0, totalPages: 1 };
try {
  const active = activeFilter !== null && activeFilter !== '' ? activeFilter === 'true' : undefined;
  const result = await listRules(sdk.db, { page, limit, search: search || undefined, active });
  rules = result.data;
  pagination = {
    page,
    limit,
    total: result.total,
    totalPages: Math.max(1, Math.ceil(result.total / limit)),
  };
} catch {
  // Silently fail — empty list shown
}

// Compute configured-status per distinct provider (not per rule) to avoid
// N×rules lookups. Uses the shared available-providers handler (registry-
// derived, mode-aware) so the badge definition matches the dropdown/guardrail.
// In dev mode the handler returns all real providers; a rule whose provider
// is not in that set (unconfigured in prod, or unknown) gets the warning badge.
const configuredProviders = new Set();
try {
  const result = await listAvailableProvidersHandler(sdk.db, 'email');
  for (const p of result.body.data) {
    if (p.configured) configuredProviders.add(p.name);
  }
} catch {
  // Silently fail
}
---

<AdminLayout title="Rules" currentPath="/admin/plugins/notifications/rules" user={user}>
  <div class="col-span-12">
    {/* Header */}
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold">Notification Rules</h1>
      <a href="/admin/plugins/notifications/rules/new" class="btn btn-primary">New Rule</a>
    </div>

    {/* Filters */}
    <div class="flex gap-4 mb-4">
      <input
        type="search"
        placeholder="Search rules..."
        class="input input-bordered flex-1 max-w-xs"
        value={search}
        id="search-input"
      />
      <select class="select select-bordered" id="active-filter">
        <option value="" selected={!activeFilter}>All</option>
        <option value="true" selected={activeFilter === 'true'}>Active</option>
        <option value="false" selected={activeFilter === 'false'}>Inactive</option>
      </select>
    </div>

    {/* Rules Table */}
    {
      rules.length === 0 ? (
        <p class="text-base-content/60">No rules found.</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr>
                <th>Event Pattern</th>
                <th>Template</th>
                <th>Provider</th>
                <th>To</th>
                <th>Status</th>
                <th />
              </tr>
            </thead>
            <tbody>
              {rules.map((rule) => (
                <tr>
                  <td>
                    <code class="bg-base-200 px-2 py-1 rounded text-sm">{rule.event_pattern}</code>
                  </td>
                  <td>{rule.template_id}</td>
                  <td>
                    <span class="badge badge-ghost">{rule.provider_name}</span>
                    {!configuredProviders.has(rule.provider_name) && (
                      <span class="badge badge-error gap-1 ml-1">⚠ provider unconfigured</span>
                    )}
                  </td>
                  <td>{rule.to}</td>
                  <td>
                    <span class={`badge ${rule.active ? 'badge-success' : 'badge-ghost'}`}>
                      {rule.active ? 'Active' : 'Inactive'}
                    </span>
                  </td>
                  <td>
                    <a
                      href={`/admin/plugins/notifications/rules/${rule.id}`}
                      class="btn btn-ghost btn-xs"
                    >
                      Edit
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }

    {/* Pagination */}
    {
      pagination.totalPages > 1 && (
        <div class="flex justify-center mt-6 gap-2">
          {pagination.page > 1 && (
            <a
              href={`?page=${pagination.page - 1}${search ? `&search=${search}` : ''}${activeFilter ? `&active=${activeFilter}` : ''}`}
              class="btn btn-sm"
            >
              ← Prev
            </a>
          )}
          <span class="btn btn-sm btn-disabled">
            Page {pagination.page} of {pagination.totalPages}
          </span>
          {pagination.page < pagination.totalPages && (
            <a
              href={`?page=${pagination.page + 1}${search ? `&search=${search}` : ''}${activeFilter ? `&active=${activeFilter}` : ''}`}
              class="btn btn-sm"
            >
              Next →
            </a>
          )}
        </div>
      )
    }
  </div>
</AdminLayout>

<script>
  document.getElementById('search-input').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') applyFilters();
  });
  document.getElementById('active-filter').addEventListener('change', applyFilters);

  function applyFilters() {
    const search = document.getElementById('search-input').value;
    const active = document.getElementById('active-filter').value;
    const params = new URLSearchParams();
    params.set('page', '1');
    if (search) params.set('search', search);
    if (active) params.set('active', active);
    window.location.href =
      '/admin/plugins/notifications/rules' + (params.toString() ? '?' + params.toString() : '');
  }
</script>
