---
/**
 * Logs list page — paginated list of notification dispatch logs.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { listLogs } from '../../../lib/data/logs.ts';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const url = new URL(Astro.url);
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));
const pageSize = 20;
const provider = url.searchParams.get('provider') || '';
const from = url.searchParams.get('from') || '';
const to = url.searchParams.get('to') || '';
const status = url.searchParams.get('status') || '';
const rule = url.searchParams.get('rule') || '';

// Read logs directly via the accessor (server-side fetch of our own admin-gated
// API would 401 — the session cookie isn't forwarded).
let logs = [];
let total = 0;
try {
  const result = await listLogs(sdk.db, {
    page,
    pageSize,
    provider: provider || undefined,
    status: status === 'success' ? 'success' : status === 'failure' ? 'failure' : undefined,
    rule: rule || undefined,
    from: from ? new Date(from) : undefined,
    to: to ? new Date(to) : undefined,
  });
  logs = result.data;
  total = result.total;
} catch {
  // Silently fail — empty list shown
}

const totalPages = Math.max(1, Math.ceil(total / pageSize));
---

<AdminLayout title="Logs" currentPath="/admin/plugins/notifications/logs" user={user}>
  <div class="col-span-12">
    {/* Header */}
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold">Dispatch Logs</h1>
      <span class="text-sm text-base-content/60">{total} total entries</span>
    </div>

    {/* Filters */}
    <div class="flex flex-wrap gap-4 items-end mb-6">
      <div class="form-control">
        <label class="label"><span class="label-text text-xs">Provider</span></label>
        <select class="select select-bordered select-sm" id="filter-provider">
          <option value="" selected={!provider}>All Providers</option>
          <option value="sendgrid" selected={provider === 'sendgrid'}>SendGrid</option>
          <option value="mailgun" selected={provider === 'mailgun'}>Mailgun</option>
          <option value="ses" selected={provider === 'ses'}>SES</option>
          <option value="smtp" selected={provider === 'smtp'}>SMTP</option>
          <option value="local" selected={provider === 'local'}>Local</option>
        </select>
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text text-xs">From Date</span></label>
        <input type="date" class="input input-bordered input-sm" id="filter-from" value={from} />
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text text-xs">To Date</span></label>
        <input type="date" class="input input-bordered input-sm" id="filter-to" value={to} />
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text text-xs">Status</span></label>
        <select class="select select-bordered select-sm" id="filter-status">
          <option value="" selected={!status}>All</option>
          <option value="success" selected={status === 'success'}>Success</option>
          <option value="failure" selected={status === 'failure'}>Failure</option>
        </select>
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text text-xs">Rule ID</span></label>
        <input
          type="text"
          class="input input-bordered input-sm"
          id="filter-rule"
          placeholder="Filter by rule ID"
          value={rule}
        />
      </div>
      <button class="btn btn-primary btn-sm" id="apply-filters">Apply</button>
      <button class="btn btn-ghost btn-sm" id="clear-filters">Clear</button>
    </div>

    {/* Logs Table */}
    {
      logs.length === 0 ? (
        <p class="text-base-content/60">No log entries found.</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr>
                <th>Date</th>
                <th>Provider</th>
                <th>Rule ID</th>
                <th>Subject</th>
                <th>Status</th>
                <th />
              </tr>
            </thead>
            <tbody>
              {logs.map((log) => (
                <tr>
                  <td class="text-sm">
                    {new Date(log.created_at).toLocaleDateString()}
                    <br />
                    <span class="text-xs text-base-content/50">
                      {new Date(log.created_at).toLocaleTimeString()}
                    </span>
                  </td>
                  <td>
                    <span class="badge badge-ghost">{log.provider_name}</span>
                  </td>
                  <td>
                    <code class="bg-base-200 px-2 py-1 rounded text-xs">
                      {log.rule_id.substring(0, 8)}...
                    </code>
                  </td>
                  <td class="max-w-xs">
                    <span class="block truncate" title={log.subject}>
                      {log.subject}
                    </span>
                  </td>
                  <td>
                    <span class={`badge ${log.success ? 'badge-success' : 'badge-error'}`}>
                      {log.success ? 'Success' : 'Failed'}
                    </span>
                  </td>
                  <td>
                    <a
                      href={`/admin/plugins/notifications/logs/${log.id}`}
                      class="btn btn-ghost btn-xs"
                    >
                      View
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }

    {/* Pagination */}
    {
      totalPages > 1 && (
        <div class="flex justify-center mt-6 gap-2">
          {page > 1 && (
            <a href={`?page=${page - 1}${buildFilterQuery()}`} class="btn btn-sm">
              ← Prev
            </a>
          )}
          <span class="btn btn-sm btn-disabled">
            Page {page} of {totalPages}
          </span>
          {page < totalPages && (
            <a href={`?page=${page + 1}${buildFilterQuery()}`} class="btn btn-sm">
              Next →
            </a>
          )}
        </div>
      )
    }
  </div>
</AdminLayout>

<script>
  function buildFilterQuery() {
    const params = new URLSearchParams();
    const provider = document.getElementById('filter-provider').value;
    const from = document.getElementById('filter-from').value;
    const to = document.getElementById('filter-to').value;
    const status = document.getElementById('filter-status').value;
    const rule = document.getElementById('filter-rule').value;
    if (provider) params.set('provider', provider);
    if (from) params.set('from', from);
    if (to) params.set('to', to);
    if (status) params.set('status', status);
    if (rule) params.set('rule', rule);
    return params.toString() ? '?' + params.toString() : '';
  }

  document.getElementById('apply-filters').addEventListener('click', () => {
    window.location.href = '/admin/plugins/notifications/logs?page=1' + buildFilterQuery();
  });

  document.getElementById('clear-filters').addEventListener('click', () => {
    window.location.href = '/admin/plugins/notifications/logs?page=1';
  });
</script>
