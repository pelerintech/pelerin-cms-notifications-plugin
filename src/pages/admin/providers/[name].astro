---
/**
 * Provider configuration page — shows provider-specific credential fields.
 */
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { db } from 'astro:db';
import { getSettingsHandler } from '../../../../api/notifications/providers/[name]/settings.ts';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const name = Astro.params.name;

const providerConfigs = {
  sendgrid: {
    label: 'SendGrid',
    icon: '✉️',
    fields: [
      { key: 'sendgrid_api_key', type: 'password', label: 'API Key', placeholder: 'SG.xxxxx' },
    ],
  },
  mailgun: {
    label: 'Mailgun',
    icon: '📧',
    fields: [
      { key: 'mailgun_url', type: 'text', label: 'API URL', placeholder: 'https://api.mailgun.net/v3/your-domain.com' },
      { key: 'mailgun_api_key', type: 'password', label: 'API Key', placeholder: 'key-xxxxx' },
    ],
  },
  ses: {
    label: 'AWS SES',
    icon: '☁️',
    fields: [
      { key: 'ses_region', type: 'text', label: 'AWS Region', placeholder: 'us-east-1' },
      { key: 'ses_access_key', type: 'password', label: 'Access Key ID', placeholder: 'AKIAxxxxx' },
      { key: 'ses_secret_key', type: 'password', label: 'Secret Access Key', placeholder: 'xxxxx' },
      { key: 'ses_from_email', type: 'text', label: 'From Email', placeholder: 'verified@yourdomain.com' },
    ],
  },
  smtp: {
    label: 'SMTP',
    icon: '📮',
    fields: [
      { key: 'smtp_host', type: 'text', label: 'SMTP Host', placeholder: 'smtp.example.com' },
      { key: 'smtp_port', type: 'number', label: 'SMTP Port', placeholder: '587' },
      { key: 'smtp_username', type: 'text', label: 'Username', placeholder: 'user@example.com' },
      { key: 'smtp_password', type: 'password', label: 'Password', placeholder: '••••••••' },
      { key: 'smtp_tls', type: 'checkbox', label: 'Use TLS', placeholder: '' },
    ],
  },
  brevo: {
    label: 'Brevo',
    icon: '🔵',
    fields: [
      { key: 'brevo_api_key', type: 'password', label: 'API Key', placeholder: 'xkeysib-...' },
      { key: 'brevo_api_url', type: 'text', label: 'API URL', placeholder: 'https://api.brevo.com/v3/smtp/email', defaultValue: 'https://api.brevo.com/v3/smtp/email' },
    ],
  },
};

const provider = providerConfigs[name];

// Load existing settings directly via the handler (server-side fetch of our own
// admin-gated API would 401 — the session cookie isn't forwarded).
let existingSettings = {};
try {
  const result = await getSettingsHandler(db, name);
  existingSettings = result.body.data;
} catch {
  // Silently fail
}
---

{!provider ? (
  <AdminLayout title="Provider Not Found" currentPath={`/admin/plugins/notifications/providers/${name}`} user={user}>
    <div class="col-span-12">
      <h1 class="text-2xl font-bold text-error">Provider not found</h1>
      <p>Unknown provider: {name}</p>
    </div>
  </AdminLayout>
) : (
  <AdminLayout title={`Configure ${provider.label}`} currentPath={`/admin/plugins/notifications/providers/${name}`} user={user}>
    <div class="col-span-12 max-w-xl">
      <h1 class="text-2xl font-bold mb-6">Configure {provider.label}</h1>

      {/* Form */}
      <form id="settings-form">
        {provider.fields.map((field) => (
          <div class="form-control mb-4">
            <label class="label">
              <span class="label-text font-medium">{field.label}</span>
            </label>
            {field.type === 'checkbox' ? (
              <input
                type="checkbox"
                name={field.key}
                class="toggle toggle-primary"
                checked={!!existingSettings[field.key]}
              />
            ) : (
              <input
                type={field.type}
                name={field.key}
                placeholder={field.placeholder}
                class="input input-bordered w-full"
                value={existingSettings[field.key] || field.defaultValue || ''}
              />
            )}
          </div>
        ))}

        {/* Actions */}
        <div class="flex gap-2 mt-6">
          <button type="submit" class="btn btn-primary">Save Configuration</button>
          <a href="/admin/plugins/notifications/providers" class="btn btn-ghost">Cancel</a>
        </div>
      </form>

      {/* Status message */}
      <div id="status-msg" class="mt-4 hidden"></div>
    </div>
  </AdminLayout>
)}

<script>
  document.getElementById('settings-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const body = {};
    for (const [key, value] of formData.entries()) {
      body[key] = value === 'on' ? 'true' : value;
    }

    const providerName = window.location.pathname.split('/').pop();
    const res = await fetch(`/api/plugins/notifications/providers/${providerName}/settings`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    const statusEl = document.getElementById('status-msg');
    if (res.ok) {
      const data = await res.json();
      statusEl.className = 'alert alert-success';
      statusEl.innerHTML = data.message || 'Settings saved successfully';
      statusEl.classList.remove('hidden');
    } else {
      const err = await res.json();
      statusEl.className = 'alert alert-error';
      statusEl.innerHTML = err.error || 'Failed to save settings';
      statusEl.classList.remove('hidden');
    }
  });
</script>
